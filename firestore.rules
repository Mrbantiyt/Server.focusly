rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /studyDays/{dayKey} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /aiChat/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // usernames/{usernameLower} = { uid }
    // Publicly readable so the client can check username availability
    // (isUsernameAvailable) before signup. Deliberately does NOT store
    // email anymore — it used to, so that username-login could resolve an
    // email before the user was authenticated, but since this doc must be
    // public, that leaked every registered user's email to anyone who
    // could guess/enumerate a username. That lookup now goes through
    // api/resolve-username.js (server-side, Admin SDK) instead, which
    // reads email from the private users/{uid} doc. Writes are still
    // locked down — only the user who owns that uid can claim/release a
    // username, and the doc may never contain anything but uid.
    match /usernames/{usernameLower} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(["uid"]);
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(["uid"]);
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
