# Copy this to .env for local dev, and add the same keys in
# Vercel Project Settings -> Environment Variables for production.

# --- Client-side (safe to expose, prefixed VITE_ so Vite bundles it) ---
VITE_SUPABASE_URL=https://dbzriyuoacufqzsjtwti.supabase.co

# --- Server-side only (Vercel functions in /api, NEVER prefix with VITE_) ---
SUPABASE_URL=https://dbzriyuoacufqzsjtwti.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Existing, unchanged:
# FIREBASE_SERVICE_ACCOUNT_KEY=...
# ONESIGNAL_APP_ID=...
# ONESIGNAL_REST_API_KEY=...

# --- Rate limiting (Upstash Redis — free tier is plenty for this app) ---
# Get these from https://console.upstash.com after creating a Redis database.
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Error monitoring (Sentry — free tier) ---
# Get a DSN from https://sentry.io after creating a project.
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# --- AI fallback provider (optional — only used if the primary provider
#     returns a 5xx error). Leave blank to disable the fallback entirely. ---
AI_API_BASE_URL_FALLBACK=https://api.openai.com/v1/chat/completions
AI_MODEL_FALLBACK=gpt-4o-mini
AI_API_KEY_FALLBACK=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Weekly Firestore backup (writes to a SEPARATE, private Supabase
#     bucket — do not reuse the public "Focusly" media bucket) ---
BACKUP_BUCKET_NAME=focusly-backups
